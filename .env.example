# 环境变量模板。
# 复制本文件为 .env，填入真实 key 后即可：
#   cp .env.example .env
# .env 已被 .gitignore 忽略，不会推送到远端。
#
# 也可以不创建 .env，直接在 shell 里临时设置：
#   PowerShell:  $env:DEEPSEEK_API_KEY="sk-..."
#   PowerShell:  $env:BAILIAN_API_KEY="sk-..."

# DeepSeek Anthropic 兼容 API（https://platform.deepseek.com/）
DEEPSEEK_API_KEY=

# 阿里云百炼 OpenAI 兼容 API（https://bailian.console.aliyun.com/），选填
BAILIAN_API_KEY=

# SiliconFlow OpenAI compatible API
SILICONFLOW_API_KEY=
SILICONFLOW_MODEL=
